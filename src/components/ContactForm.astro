---
// Client-side contact form posting to /api/contact
---
<form id="contact-form" class="space-y-5" novalidate>
  <p class="text-xs text-navy-500"><span class="text-gold-700" aria-hidden="true">*</span> Required fields</p>
  <div class="grid sm:grid-cols-2 gap-5">
    <div>
      <label for="name" class="block text-xs uppercase tracking-[0.15em] text-navy font-semibold mb-2">Your Name <span class="text-gold-700" aria-hidden="true">*</span></label>
      <input id="name" name="name" type="text" required autocomplete="name" aria-required="true"
        class="w-full px-4 py-3 bg-white border border-navy-100 rounded-sm focus:border-gold-600 focus:ring-2 focus:ring-gold-600/30 outline-none transition" />
    </div>
    <div>
      <label for="phone" class="block text-xs uppercase tracking-[0.15em] text-navy font-semibold mb-2">Phone Number <span class="text-gold-700" aria-hidden="true">*</span></label>
      <input id="phone" name="phone" type="tel" required autocomplete="tel" aria-required="true"
        class="w-full px-4 py-3 bg-white border border-navy-100 rounded-sm focus:border-gold-600 focus:ring-2 focus:ring-gold-600/30 outline-none transition" />
    </div>
  </div>
  <div>
    <label for="email" class="block text-xs uppercase tracking-[0.15em] text-navy font-semibold mb-2">Email Address <span class="text-gold-700" aria-hidden="true">*</span></label>
    <input id="email" name="email" type="email" required autocomplete="email" aria-required="true"
      class="w-full px-4 py-3 bg-white border border-navy-100 rounded-sm focus:border-gold-600 focus:ring-2 focus:ring-gold-600/30 outline-none transition" />
  </div>
  <div>
    <label for="message" class="block text-xs uppercase tracking-[0.15em] text-navy font-semibold mb-2">Your Message <span class="text-gold-700" aria-hidden="true">*</span></label>
    <textarea id="message" name="message" rows="5" required aria-required="true"
      class="w-full px-4 py-3 bg-white border border-navy-100 rounded-sm focus:border-gold-600 focus:ring-2 focus:ring-gold-600/30 outline-none transition resize-y"></textarea>
  </div>
  <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
  <div class="flex items-center gap-4">
    <button type="submit" id="submit-btn" class="btn-gold">
      <span>Send Message</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const fields = ['name', 'phone', 'email', 'message'] as const;

  const clearErrors = () => {
    fields.forEach((id) => {
      const el = document.getElementById(id);
      el?.setAttribute('aria-invalid', 'false');
      el?.removeAttribute('aria-describedby');
    });
  };

  const markInvalid = (id: string, msg: string) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.setAttribute('aria-invalid', 'true');
    el.setAttribute('aria-describedby', 'form-status');
    status.textContent = msg;
    status.className = 'text-sm text-red-700';
    (el as HTMLInputElement).focus();
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();
    status.textContent = '';
    status.className = 'text-sm';

    const data = Object.fromEntries(new FormData(form));
    for (const id of fields) {
      const val = (data[id] as string || '').trim();
      if (!val) {
        markInvalid(id, `Please enter your ${id === 'message' ? 'message' : id}.`);
        return;
      }
    }
    const emailVal = (data.email as string).trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
      markInvalid('email', 'Please enter a valid email address.');
      return;
    }

    btn.disabled = true;
    const span = btn.querySelector('span')!;
    const original = span.textContent;
    span.textContent = 'Sending...';
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json().catch(() => ({}));
      if (res.ok) {
        form.reset();
        status.textContent = "Thanks. Your message was sent. We'll be in touch shortly.";
        status.className = 'text-sm text-green-700';
      } else {
        status.textContent = json.error || 'Something went wrong. Please call us.';
        status.className = 'text-sm text-red-700';
      }
    } catch {
      status.textContent = 'Network error. Please try again or call us.';
      status.className = 'text-sm text-red-700';
    } finally {
      btn.disabled = false;
      span.textContent = original;
    }
  });
</script>
