---
import { t, getLocale } from '@/i18n';
const locale = getLocale(Astro.url.pathname);
const tr = t(locale);
---
<form id="contact-form" class="space-y-5" novalidate data-locale={locale}>
  <p class="text-xs text-navy-500"><span class="text-gold-800" aria-hidden="true">*</span> {tr.form.requiredHint}</p>
  <div class="grid sm:grid-cols-2 gap-5">
    <div>
      <label for="name" class="block text-xs uppercase tracking-[0.15em] text-navy font-semibold mb-2">{tr.form.name} <span class="text-gold-800" aria-hidden="true">*</span></label>
      <input id="name" name="name" type="text" required autocomplete="name" aria-required="true"
        class="w-full px-4 py-3 bg-white border border-navy-100 rounded-sm focus:border-gold-600 focus:ring-2 focus:ring-gold-600/30 outline-none transition" />
    </div>
    <div>
      <label for="phone" class="block text-xs uppercase tracking-[0.15em] text-navy font-semibold mb-2">{tr.form.phone} <span class="text-gold-800" aria-hidden="true">*</span></label>
      <input id="phone" name="phone" type="tel" required autocomplete="tel" aria-required="true"
        class="w-full px-4 py-3 bg-white border border-navy-100 rounded-sm focus:border-gold-600 focus:ring-2 focus:ring-gold-600/30 outline-none transition" />
    </div>
  </div>
  <div>
    <label for="email" class="block text-xs uppercase tracking-[0.15em] text-navy font-semibold mb-2">{tr.form.email} <span class="text-gold-800" aria-hidden="true">*</span></label>
    <input id="email" name="email" type="email" required autocomplete="email" aria-required="true"
      class="w-full px-4 py-3 bg-white border border-navy-100 rounded-sm focus:border-gold-600 focus:ring-2 focus:ring-gold-600/30 outline-none transition" />
  </div>
  <div>
    <label for="message" class="block text-xs uppercase tracking-[0.15em] text-navy font-semibold mb-2">{tr.form.message} <span class="text-gold-800" aria-hidden="true">*</span></label>
    <textarea id="message" name="message" rows="5" required aria-required="true"
      class="w-full px-4 py-3 bg-white border border-navy-100 rounded-sm focus:border-gold-600 focus:ring-2 focus:ring-gold-600/30 outline-none transition resize-y"></textarea>
  </div>
  <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
  <div class="flex items-center gap-4">
    <button type="submit" id="submit-btn" class="btn-gold">
      <span>{tr.form.send}</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
  </div>

  <script type="application/json" id="form-i18n" set:html={JSON.stringify({
    sending: tr.form.sending,
    success: tr.form.success,
    network: tr.form.network,
    failed: tr.form.failed,
    invalid: tr.form.invalid,
    invalidEmail: tr.form.invalidEmail,
    fieldNames: {
      name: tr.form.name.toLowerCase(),
      phone: tr.form.phone.toLowerCase(),
      email: tr.form.email.toLowerCase(),
      message: tr.form.message.toLowerCase(),
    },
  })} />
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const i18nNode = document.getElementById('form-i18n');
  const i18n = i18nNode ? JSON.parse(i18nNode.textContent || '{}') : {};
  const fields = ['name', 'phone', 'email', 'message'] as const;

  const clearErrors = () => {
    fields.forEach((id) => {
      const el = document.getElementById(id);
      el?.setAttribute('aria-invalid', 'false');
      el?.removeAttribute('aria-describedby');
    });
  };

  const markInvalid = (id: string, msg: string) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.setAttribute('aria-invalid', 'true');
    el.setAttribute('aria-describedby', 'form-status');
    status.textContent = msg;
    status.className = 'text-sm text-red-700';
    (el as HTMLInputElement).focus();
  };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();
    status.textContent = '';
    status.className = 'text-sm';

    const data = Object.fromEntries(new FormData(form));
    for (const id of fields) {
      const val = ((data[id] as string) || '').trim();
      if (!val) {
        markInvalid(id, `${i18n.invalid} ${i18n.fieldNames?.[id] ?? id}.`);
        return;
      }
    }
    const emailVal = (data.email as string).trim();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
      markInvalid('email', i18n.invalidEmail);
      return;
    }

    btn.disabled = true;
    const span = btn.querySelector('span')!;
    const original = span.textContent;
    span.textContent = i18n.sending;
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const json = await res.json().catch(() => ({}));
      if (res.ok) {
        form.reset();
        status.textContent = i18n.success;
        status.className = 'text-sm text-green-700';
      } else {
        status.textContent = json.error || i18n.failed;
        status.className = 'text-sm text-red-700';
      }
    } catch {
      status.textContent = i18n.network;
      status.className = 'text-sm text-red-700';
    } finally {
      btn.disabled = false;
      span.textContent = original;
    }
  });
</script>
