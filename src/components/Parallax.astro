---
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  height?: string;
  overlay?: string;
  class?: string;
}

const { image, height = 'min-h-[420px]', overlay = 'bg-navy/70', class: cls = '' } = Astro.props;
const optimized = await getImage({ src: image, format: 'webp', width: 1920, quality: 78 });
---
<section
  class:list={['parallax relative flex items-center', height, cls]}
  style={`background-image: url('${optimized.src}')`}
>
  <div class:list={['absolute inset-0', overlay]} aria-hidden="true"></div>
  <div class="relative container-x w-full text-white">
    <slot />
  </div>
</section>
