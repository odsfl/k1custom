---
import { testimonials } from '@/data/testimonials';
import { t, getLocale } from '@/i18n';
const locale = getLocale(Astro.url.pathname);
const tr = t(locale);

interface Props { limit?: number; }
const { limit } = Astro.props;
const items = limit ? testimonials.slice(0, limit) : testimonials;
---
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
  {items.map((t) => (
    <figure class="reveal bg-white p-7 rounded-sm border-l-4 border-gold-600 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 flex flex-col">
      <div class="flex gap-0.5 text-gold-600 mb-4" aria-label={tr.ui.fiveStars}>
        {[...Array(5)].map(() => (
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 15l-5.2 2.8 1-5.9L1.5 7.7l5.9-.9z"/></svg>
        ))}
      </div>
      <blockquote class="text-navy-500 leading-relaxed text-[15px] flex-1 italic">"{t.quote}"</blockquote>
      <figcaption class="mt-5 pt-5 border-t border-navy-50 font-semibold text-navy">{t.name}</figcaption>
    </figure>
  ))}
</div>
