---
import { site } from '@/data/site';
const items = [
  { label: 'Visit Us', value: `${site.address.street}, ${site.address.city}, ${site.address.region} ${site.address.postal}`, icon: 'pin', valueClass: 'text-sm md:text-base break-words' },
  { label: 'Call Us', value: site.phone, href: site.phoneHref, icon: 'phone', valueClass: 'text-sm md:text-base whitespace-nowrap' },
  { label: 'Email Us', value: site.email, href: `mailto:${site.email}`, icon: 'mail', valueClass: 'text-xs md:text-sm break-all' },
  { label: 'Hours', value: 'Mon to Sat · 9am to 6pm', icon: 'clock', valueClass: 'text-sm md:text-base' },
];
---
<section class="bg-navy text-white">
  <div class="container-x grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/10">
    {items.map((it) => (
      <div class="bg-navy p-5 md:p-7 flex items-start gap-3 md:gap-4">
        <div class="flex-shrink-0 w-10 h-10 md:w-11 md:h-11 rounded-full bg-gold-300/15 text-gold-300 flex items-center justify-center">
          {it.icon === 'pin' && <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-7.5 8-13a8 8 0 1 0-16 0c0 5.5 8 13 8 13z" stroke-linejoin="round"/><circle cx="12" cy="9" r="2.5"/></svg>}
          {it.icon === 'phone' && <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.6a2 2 0 0 1-.5 2.1L8 9.6a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.4c.8.3 1.7.5 2.6.6a2 2 0 0 1 1.7 2.1z" stroke-linejoin="round"/></svg>}
          {it.icon === 'mail' && <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>}
          {it.icon === 'clock' && <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2" stroke-linecap="round"/></svg>}
        </div>
        <div class="min-w-0 flex-1">
          <div class="text-[10px] uppercase tracking-[0.18em] text-gold-300 font-semibold mb-1">{it.label}</div>
          {it.href ? (
            <a href={it.href} class:list={[it.valueClass, 'hover:text-gold-300 transition block']}>{it.value}</a>
          ) : (
            <div class:list={[it.valueClass]}>{it.value}</div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
