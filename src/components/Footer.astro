---
import { Image } from 'astro:assets';
import logo from '@/assets/logo.png';
import { site } from '@/data/site';
import { t, type Locale } from '@/i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const tr = t(locale);

const nav = [
  { href: tr.paths.home, label: tr.nav.home },
  { href: tr.paths.about, label: tr.nav.about },
  { href: tr.paths.services, label: tr.nav.services },
  { href: tr.paths.gallery, label: tr.nav.gallery },
  { href: tr.paths.testimonials, label: tr.nav.testimonials },
  { href: tr.paths.contact, label: tr.nav.contact },
];
const year = new Date().getFullYear();
const socials = [
  { url: site.social.facebook, label: tr.social.fb, icon: 'fb' },
  { url: site.social.instagram, label: tr.social.ig, icon: 'ig' },
  { url: site.social.google, label: tr.social.google, icon: 'g' },
].filter((s): s is { url: string; label: string; icon: string } => typeof s.url === 'string' && s.url.length > 0);
---
<footer class="bg-navy-700 text-white/85 mt-24">
  <div class="container-x py-16 grid gap-10 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="mb-5 inline-block">
        <Image src={logo} alt={`${site.name} logo`} width={220} height={80} class="h-16 w-auto" />
      </div>
      <div class="text-[10px] uppercase tracking-[0.2em] text-gold-300 font-semibold mb-4">{tr.footerLocation} {site.foundingYear}</div>
      <p class="text-sm leading-relaxed text-white/85 max-w-md">{tr.footerBlurb}</p>
      {socials.length > 0 && (
        <div class="flex items-center gap-3 mt-6">
          {socials.map((s) => (
            <a
              href={s.url}
              aria-label={s.label}
              class="inline-flex items-center justify-center h-11 w-11 rounded-full text-gold-300 hover:text-white hover:bg-white/10 transition"
              target="_blank"
              rel="noopener noreferrer"
            >
              {s.icon === 'fb' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.3.2 2.3.2v2.5h-1.3c-1.3 0-1.7.8-1.7 1.6V12h2.9l-.5 2.9h-2.4v7A10 10 0 0 0 22 12z"/></svg>
              )}
              {s.icon === 'ig' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2 0 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.1.4.4 1 .4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c0 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.1-1 .4-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2 0-1.8-.3-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.1-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c0-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.1 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zM12 0C8.7 0 8.3 0 7.1.1 5.8.1 5 .3 4.2.6c-.8.3-1.5.8-2.2 1.5C1.3 2.8.8 3.5.5 4.3.3 5 .1 5.8.1 7.1 0 8.3 0 8.7 0 12s0 3.7.1 4.9c.1 1.3.3 2.1.5 2.9.3.8.8 1.5 1.5 2.2.7.7 1.4 1.2 2.2 1.5.8.3 1.6.4 2.9.5 1.2.1 1.6.1 4.9.1s3.7 0 4.9-.1c1.3-.1 2.1-.3 2.9-.5.8-.3 1.5-.8 2.2-1.5.7-.7 1.2-1.4 1.5-2.2.3-.8.4-1.6.5-2.9.1-1.2.1-1.6.1-4.9s0-3.7-.1-4.9c-.1-1.3-.3-2.1-.5-2.9-.3-.8-.8-1.5-1.5-2.2C21.2 1.3 20.5.8 19.7.5 18.9.3 18.1.1 16.8 0 15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4 6.2 6.2 0 0 0 0-12.4zm0 10.2a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-10.4a1.4 1.4 0 1 0 0-2.9 1.4 1.4 0 0 0 0 2.9z"/></svg>
              )}
              {s.icon === 'g' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 10.2v3.9h5.5c-.2 1.4-1.7 4.2-5.5 4.2-3.3 0-6-2.7-6-6.1s2.7-6.1 6-6.1c1.9 0 3.1.8 3.8 1.5l2.6-2.5C16.7 3.7 14.6 2.8 12 2.8 6.9 2.8 2.8 6.9 2.8 12S6.9 21.2 12 21.2c6.9 0 9.2-4.8 9.2-7.4 0-.5 0-.9-.1-1.3H12z"/></svg>
              )}
            </a>
          ))}
        </div>
      )}
    </div>

    <nav aria-label={tr.ui.footer}>
      <h2 class="text-white font-serif text-xl tracking-wide uppercase mb-4">{tr.ui.quickLinks}</h2>
      <ul class="space-y-2 text-sm">
        {nav.map((n) => (
          <li><a href={n.href} class="hover:text-gold-300 transition">{n.label}</a></li>
        ))}
      </ul>
    </nav>

    <div>
      <h2 class="text-white font-serif text-xl tracking-wide uppercase mb-4">{tr.ui.getInTouch}</h2>
      <ul class="space-y-3 text-sm">
        <li><a href={site.phoneHref} class="hover:text-gold-300 transition">{site.phone}</a></li>
        <li><a href={`mailto:${site.email}`} class="hover:text-gold-300 transition break-all">{site.email}</a></li>
        <li>{site.address.street}<br />{site.address.city}, {site.address.region} {site.address.postal}</li>
        <li class="pt-2 border-t border-white/10">
          <div class="text-white/85">{tr.hours.weekdays}</div>
          <div class="text-white/85">{tr.hours.weekend}</div>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-x py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/85">
      <div>© {year} {site.name}. {tr.ui.rights}</div>
      <div>
        {tr.ui.webDesignBy} <a href="https://oceanfrontdigitalsolutions.com" target="_blank" rel="noopener noreferrer" class="text-gold-300 hover:text-white transition">Oceanfront Digital Solutions</a>
      </div>
    </div>
  </div>
</footer>
