---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  blurb: string;
  image: ImageMetadata;
  href?: string;
}
const { title, blurb, image, href = '/services' } = Astro.props;
---
<article class="reveal group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-2xl hover:shadow-navy/10 transition-all duration-500 flex flex-col">
  <a href={href} class="block overflow-hidden aspect-[16/9]" tabindex="-1" aria-hidden="true">
    <Image
      src={image}
      alt=""
      widths={[400, 600, 900]}
      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
    />
  </a>
  <div class="p-7 flex-1 flex flex-col">
    <h3 class="font-serif text-2xl text-navy">{title}</h3>
    <div class="gold-rule"></div>
    <p class="text-navy-500 text-sm leading-relaxed flex-1">{blurb}</p>
    <a href={href} aria-label={`Learn more about ${title}`} class="mt-5 inline-flex items-center text-sm font-semibold text-gold-700 group-hover:text-navy transition-colors">
      Learn More
      <svg class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</article>
