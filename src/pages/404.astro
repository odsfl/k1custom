---
import Base from '@/layouts/Base.astro';
---
<Base title="Page Not Found" description="The page you're looking for doesn't exist." path="/404" noindex>
  <section class="py-32 text-center container-x">
    <div class="font-serif text-7xl text-gold">404</div>
    <h1 class="section-title mt-4">Page Not Found</h1>
    <div class="gold-rule mx-auto"></div>
    <p class="lead max-w-md mx-auto">The page you're looking for might have moved or never existed. Let's get you back on track.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn-gold">Back to Home</a>
      <a href="/contact/" class="btn-outline-navy">Contact Us</a>
    </div>
  </section>
</Base>
