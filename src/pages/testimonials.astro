---
import Base from '@/layouts/Base.astro';
import Parallax from '@/components/Parallax.astro';
import Testimonials from '@/components/Testimonials.astro';
import bg from '@/assets/images/gallery/project-09.jpg';
import cta from '@/assets/images/gallery/project-27.jpg';
import { testimonials } from '@/data/testimonials';
import { site } from '@/data/site';

// Individual Review schema only (no aggregateRating without verifiable source).
// Google enforces a manual-action policy on aggregateRating without a third-party source.
const reviewSchema = {
  '@context': 'https://schema.org',
  '@graph': testimonials.map((t) => ({
    '@type': 'Review',
    itemReviewed: { '@id': `${site.url}/#business` },
    author: { '@type': 'Person', name: t.name },
    reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
    reviewBody: t.quote,
  })),
};
---
<Base
  title="Reviews | K-1 Custom Orlando Car Audio & Window Tint"
  description="Real customer reviews of K-1 Custom in Orlando, FL. See what drivers say about our car audio installs, window tinting, ceramic coatings, wraps, and customer service."
  path="/testimonials"
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Testimonials', url: '/testimonials/' }]}
>
  <Parallax image={bg} overlay="bg-navy/85" height="min-h-[340px]">
    <div class="text-center py-12">
      <span class="eyebrow !text-gold-200">Reviews</span>
      <h1 class="font-serif text-4xl md:text-5xl text-white uppercase">K-1 Custom Reviews — What Orlando Drivers Say</h1>
      <p class="text-white/90 mt-4 max-w-2xl mx-auto">
        Repeat customers, word-of-mouth referrals, and 5-star feedback. Here's a snapshot of what Orlando drivers say about K-1 Custom.
      </p>
    </div>
  </Parallax>

  <section class="py-24">
    <div class="container-x">
      <Testimonials />
      <p class="mt-12 text-center text-sm text-navy-500">
        Want to read more verified reviews?
        {site.social.google && (
          <a href={site.social.google} target="_blank" rel="noopener noreferrer" class="text-gold-700 underline underline-offset-2 hover:text-navy">See us on Google Business</a>
        )}
      </p>
    </div>
  </section>

  <Parallax image={cta} overlay="bg-navy/85" height="min-h-[320px]">
    <div class="text-center py-12">
      <h2 class="font-serif text-3xl md:text-4xl text-white uppercase">Ready to Be Our Next Happy Customer?</h2>
      <a href="/contact/" class="btn-gold mt-8">Get Started</a>
    </div>
  </Parallax>

  <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
</Base>
