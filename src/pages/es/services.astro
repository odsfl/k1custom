---
import Base from '@/layouts/Base.astro';
import Parallax from '@/components/Parallax.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import bg from '@/assets/images/gallery/project-14.jpg';
import cta from '@/assets/images/gallery/project-28.jpg';
import { services, fullServices, additionalServices } from '@/data/services.es';
import { site } from '@/data/site';
---
<Base
  title="Audio, Polarizado y Personalización en Orlando | K-1 Custom"
  description="K-1 Custom en Orlando: audio para autos, polarizado, corrección de pintura, recubrimiento cerámico, vinilos, fibra de vidrio, GPS, seguridad, encendido remoto y servicios de flotillas."
  path="/es/services"
  locale="es"
  breadcrumbs={[{ name: 'Inicio', url: '/es/' }, { name: 'Servicios', url: '/es/services/' }]}
>
  <Parallax image={bg} overlay="bg-navy/85" height="min-h-[340px]">
    <div class="text-center py-12">
      <span class="eyebrow !text-gold-200">Lo Que Hacemos</span>
      <h1 class="font-serif text-4xl md:text-5xl text-white uppercase">Nuestros Servicios</h1>
      <p class="text-white/90 mt-4 max-w-2xl mx-auto">
        Instalación profesional de audio para autos, polarizado, recubrimiento cerámico, vinilos, seguridad y accesorios. Sea tu auto de diario, un proyecto especial o una flotilla, entregamos instalaciones limpias y rendimiento confiable.
      </p>
    </div>
  </Parallax>

  <section class="py-24">
    <div class="container-x">
      <SectionHeader eyebrow="Trabajo Destacado" title="Donde Brillamos" lead="Nuestros servicios más solicitados, dominados por instaladores profesionales." />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-14">
        {services.map((s) => <ServiceCard {...s} href="/es/services/" />)}
      </div>
    </div>
  </section>

  <section class="py-24 bg-stone/50">
    <div class="container-x max-w-5xl">
      <SectionHeader eyebrow="Menú Completo" title="Todo lo Que Ofrecemos" />
      <div class="mt-14 space-y-6">
        {fullServices.map((s, i) => (
          <article class="reveal bg-white p-8 md:p-10 rounded-sm border-l-4 border-gold-600 flex flex-col md:flex-row gap-6 md:gap-10 items-start">
            <div class="font-serif text-5xl text-gold-600/50 leading-none flex-shrink-0">0{i + 1}</div>
            <div>
              <h3 class="font-serif text-2xl text-navy uppercase">{s.title}</h3>
              <p class="text-navy-500 leading-relaxed mt-3">{s.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="container-x">
      <SectionHeader eyebrow="Y Más" title="Capacidades Adicionales" lead="Si no lo ves aquí, pregúntanos. Lo más probable es que también lo instalemos." />
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mt-12 max-w-5xl mx-auto">
        {additionalServices.map((m) => (
          <div class="reveal bg-white border border-navy-50 px-5 py-4 text-center text-sm font-medium text-navy-600">{m}</div>
        ))}
      </div>
    </div>
  </section>

  <Parallax image={cta} overlay="bg-navy/85" height="min-h-[360px]">
    <div class="text-center py-12">
      <h2 class="font-serif text-3xl md:text-4xl text-white uppercase">¿Listo para Construir Tu Auto?</h2>
      <p class="text-white/90 mt-3 max-w-lg mx-auto">Cuéntanos lo que tienes en mente y nosotros nos encargamos del resto, desde la selección hasta la instalación final.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/es/contact/" class="btn-gold">Solicita una Cotización Gratis</a>
        <a href="/es/gallery/" class="btn-outline">Ver Proyectos</a>
      </div>
    </div>
  </Parallax>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': fullServices.map((s, i) => ({
      '@type': 'Service',
      '@id': `${site.url}/es/services/#service-${i + 1}`,
      name: s.title,
      serviceType: s.title,
      description: s.body,
      url: `${site.url}/es/services/`,
      inLanguage: 'es',
      provider: { '@id': `${site.url}/#business` },
      areaServed: site.serviceArea.map((c) => ({ '@type': 'City', name: c })),
    })),
  })} />
</Base>
