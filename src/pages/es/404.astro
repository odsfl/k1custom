---
import Base from '@/layouts/Base.astro';
---
<Base title="Página No Encontrada" description="La página que buscas no existe." path="/es/404" locale="es" noindex>
  <section class="py-32 text-center container-x">
    <div class="font-serif text-7xl text-gold-700">404</div>
    <h1 class="section-title mt-4">Página No Encontrada</h1>
    <div class="gold-rule mx-auto"></div>
    <p class="lead max-w-md mx-auto">La página que buscas pudo haberse movido o nunca existió. Te llevamos de vuelta a casa.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/es/" class="btn-gold">Volver al Inicio</a>
      <a href="/es/contact/" class="btn-outline-navy">Contáctanos</a>
    </div>
  </section>
</Base>
